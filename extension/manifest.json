{
  "manifest_version": 3,
  "name": "Cafe MD - Markdown Viewer",
  "version": "1.0.0",
  "description": "View and edit Markdown files in browser with Cafe MD",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Open Cafe MD"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "contextMenus"
  ],
  "host_permissions": [
    "file:///*"
  ],
  "file_browser_handlers": [
    {
      "id": "cafe-md-open",
      "default_title": "Open with Cafe MD",
      "file_filters": [
        {
          "name": "Markdown Files",
          "extensions": ["md", "markdown", "txt"]
        }
      ]
    }
  ]
}
